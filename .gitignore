# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/*

# Data files (large files - don't commit raw satellite data)
data/raw/*
!data/raw/.gitkeep
*.tif
*.tiff
*.h5
*.nc
*.zip
*.tar.gz

# Logs & outputs (except final maps)
*.log
outputs/temp/*
!outputs/maps/.gitkeep
!outputs/plots/.gitkeep

# Environment variables
.env
.env.local

# IDE & Editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Google Earth Engine credentials (never commit)
.ee_auth/
credentials.json

# Large model files
*.h5
*.onnx
*.pb
models/saved_models/*

# Temporary files
temp/
tmp/
cache/
